# ── LINE Messaging API ──────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
# 只有這些 LINE userId 能審核/發布(逗號分隔)。這是防止外人觸發全公司寄信的關鍵。
LINE_ADMIN_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
# 可用模型字串請以官方文件為準:https://docs.claude.com/en/api/overview
ANTHROPIC_MODEL=claude-sonnet-5

# ── Google Sheets ───────────────────────────────────────────────────
# service account 的 JSON 金鑰檔路徑;記得把該 service account email 分享到你的試算表
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
SPREADSHEET_ID=your-spreadsheet-id
SOURCE_SHEET=source
EMPLOYEE_SHEET=employees
LOG_SHEET=log
# 來源分頁裡「這批要寄給誰」的欄位名稱(值為逗號分隔的員編)
SOURCE_RECIPIENTS_COLUMN=員編
# 員工對照分頁的欄位名稱
EMPLOYEE_ID_COLUMN=員編
EMPLOYEE_EMAIL_COLUMN=email

# ── SMTP 寄信 ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@example.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=your-account@example.com

# ── 其他 ────────────────────────────────────────────────────────────
# 對外可存取的網址(給 Line 預覽連結用),結尾不要加斜線
PUBLIC_BASE_URL=https://your-app.example.com
DATABASE_PATH=./workflow.db
# 手動觸發 /batches/start 用的簡易保護 token
START_API_TOKEN=change-me
